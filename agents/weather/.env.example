# Copy to `.env` for LOCAL testing only (`langgraph dev`). Do NOT commit a real key,
# and do NOT bake this into the image — in Kubernetes the key is injected at runtime
# by the Helm chart from a Secret (see docs/deployment-guide.md).

# Required: Anthropic API key used by the Claude model.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (format "<provider>:<model-id>").
# MODEL_NAME=anthropic:claude-sonnet-5

# Optional: send traces to LangSmith while testing locally.
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_TRACING=true
